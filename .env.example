# EWIS Dashboard mobile — Supabase (same cloud project as the web dashboard).
# Copy to .env and fill from Supabase Dashboard -> Settings -> API keys.
#
# Only the publishable (anon) key belongs in a mobile app. It respects RLS.
# NEVER add SUPABASE_SECRET_KEY here — the secret key bypasses RLS and must
# stay server-side only (see Hard Rule #1).
EXPO_PUBLIC_SUPABASE_URL=https://<your-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
